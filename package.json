{
	"name": "nuxt-ui-template-starter",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev --port 3699",
		"preview": "nuxt preview --port 3699",
		"postinstall": "nuxt prepare",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "nuxt typecheck",
		"db:push": "drizzle-kit push",
		"db:seed": "node ./scripts/seed-dev.mjs",
		"db:studio": "drizzle-kit studio",
		"auth:db": "npx @better-auth/cli@latest generate --config ./modules/auth/runtime/server/utils/auth.ts --output ./server/database/schema/auth.ts --yes"
	},
	"dependencies": {
		"@ai-sdk/openai": "^2.0.77",
		"@ai-sdk/openai-compatible": "^1.0.41",
		"@ai-sdk/vue": "^2.0.108",
		"@iconify-json/lucide": "^1.2.79",
		"@iconify-json/simple-icons": "^1.2.61",
		"@nuxt/ui": "^4.2.1",
		"@nuxtjs/i18n": "10.2.1",
		"@nuxtjs/mdc": "0.19.1",
		"@vue-email/components": "^0.0.21",
		"@vue-email/render": "^0.0.9",
		"@vueuse/nuxt": "^14.1.0",
		"@vueuse/router": "^14.1.0",
		"ai": "^5.0.108",
		"better-auth": "^1.4.5",
		"drizzle-orm": "^0.45.0",
		"h3-zod": "^0.5.3",
		"mysql2": "^3.15.3",
		"nuxt": "^4.2.1",
		"nuxt-api-shield": "^0.10.0",
		"resend": "^6.5.2"
	},
	"devDependencies": {
		"@nuxt/eslint": "^1.11.0",
		"drizzle-kit": "^0.31.8",
		"eslint": "9.39.1",
		"nuxt-file-storage": "^0.3.0",
		"typescript": "^5.9.3",
		"ulid": "^3.0.2",
		"vue-tsc": "^3.1.6"
	},
	"resolutions": {
		"eslint": "9.37.0"
	},
	"packageManager": "pnpm@10.17.1"
}
